{
  "name": "@vizo-o/phone-package",
  "version": "0.1.4",
  "description": "Phone number utilities for European phone number support",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"*.{json,js,mjs}\" \".*rc\" 2>/dev/null || true",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=0 --fix && prettier --write \"*.{json,js,mjs}\" \".*rc\" 2>/dev/null || true",
    "audit": "npm audit --audit-level=moderate",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "pre-release": "npm run lint && npm run audit && npm run type-check && npm test && npm run build",
    "release-auto": "release-it --ci minor",
    "release": "release-it",
    "release:ci": "npm run pre-release && release-it --ci"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vizo-o/phone-package.git"
  },
  "author": "Gilaad Elstein",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/vizo-o/phone-package/issues"
  },
  "homepage": "https://github.com/vizo-o/phone-package#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "phone": "^3.1.44"
  },
  "overrides": {
    "fast-xml-parser": ">=5.5.7",
    "minimatch": ">=10.2.1",
    "undici": ">=6.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vizo-o/dev-tools": "^1.0.47",
    "chalk": "^4.1.2",
    "eslint": "^8.57.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-promise": "^6.6.0",
    "jest": "^30.2.0",
    "release-it": "^19.0.3",
    "ts-jest": "^29.4.5",
    "typescript": "^5.8.2"
  }
}
